PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
PUBLIC_POSTHOG_KEY=phc_your-posthog-project-api-key

# /inventory reads live listings from the CARD-BOOKS Supabase project (a
# DIFFERENT project than the one above -- Nathan's private bookkeeping app,
# not this site's own waitlist DB). This is deliberately its own anon key,
# not reused from PUBLIC_SUPABASE_*, so the two projects never get mixed up.
# Safe to publish: the card-books project's anon key can only ever read
# `public_catalogue`, a security-barrier view exposing exactly six columns
# (player, card_desc, team, market_value, currency, photo_path) for cards
# Nathan has explicitly listed for sale -- see that project's
# supabase/migrations/0007_public_catalogue.sql for the full privacy rule.
PUBLIC_CARD_BOOKS_SUPABASE_URL=https://your-card-books-project.supabase.co
PUBLIC_CARD_BOOKS_SUPABASE_ANON_KEY=your-card-books-anon-key
