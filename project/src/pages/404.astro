---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="404 — Page Not Found — Slab Savvy"
  description="The page you're looking for doesn't exist."
>
  <Navigation />
  <main class="flex-1">
    <div class="min-h-[60vh] flex items-center justify-center">
      <div class="text-center px-4">
        <h1 class="font-headline text-6xl md:text-8xl text-ssc-gold tracking-wide mb-4">404</h1>
        <p class="font-body text-lg text-ssc-text-muted mb-8">Page not found.</p>
        <a href="/" class="btn-shine inline-flex items-center min-h-[44px] px-8 py-3 bg-ssc-gold text-white font-body font-semibold hover:bg-ssc-gold-dark">
          Back to Home
        </a>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
