---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import MobileStickyCTA from '../components/MobileStickyCTA.astro';
import { InventoryGrid } from '../components/InventoryGrid';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  '@id': 'https://www.slabsavvycpa.com/inventory#collection',
  name: 'Live Card Inventory',
  description: "Sports cards currently for sale, priced at market value, from Nathan Wiebe's own collection.",
  isPartOf: { '@id': 'https://www.slabsavvycpa.com/#website' },
};

const clipboardIcon = `<svg class="w-6 h-6 text-ssc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`;
const cameraIcon = `<svg class="w-6 h-6 text-ssc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="square" stroke-linejoin="miter" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /></svg>`;
const bookIcon = `<svg class="w-6 h-6 text-ssc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>`;
---

<BaseLayout
  title="Live Card Inventory | Slab Savvy"
  description="Sports cards currently for sale, priced at market value. Message on Facebook to buy."
  jsonLd={jsonLd}
>
  <Navigation />
  <main class="flex-1 bg-ssc-bg">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 pb-28 md:pb-24">

      <header class="mb-10 md:mb-14 text-center">
        <p class="font-headline text-sm md:text-base tracking-[0.3em] text-ssc-gold mb-3">FOR SALE</p>
        <h1 class="font-headline text-4xl md:text-6xl text-ssc-text tracking-wide leading-none mb-6">
          LIVE CARD <span class="text-ssc-gold">INVENTORY</span>
        </h1>
        <p class="font-body text-base md:text-lg text-ssc-text-muted max-w-2xl mx-auto">
          Cards currently for sale from my own collection, priced at market value.
          See something you like? Message me on Facebook.
        </p>
      </header>

      <section aria-label="Cards for sale" class="mb-16 md:mb-20">
        <InventoryGrid client:load />
      </section>

      <section class="border-t border-ssc-text/10 pt-10 md:pt-14" data-animate="blur-fade" style="opacity: 0">
        <div class="text-center mb-8">
          <h2 class="font-headline text-2xl md:text-3xl text-ssc-text tracking-wide mb-3">
            MORE FROM <span class="text-ssc-gold">SLAB SAVVY</span>
          </h2>
          <p class="font-body text-ssc-text-muted max-w-xl mx-auto">
            Buying a card isn't the only thing I do here. If you deal cards yourself, these might help too.
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
          <ProductCard
            title="SLAB SAVVY TRACKER"
            description="Stop using a Notes app to track your inventory. Send a photo, confirm the details, get a row in your spreadsheet with comps."
            iconSvg={clipboardIcon}
            href="/waitlist"
            cta="Join the Waitlist"
            gradient="bg-gradient-to-r from-ssc-gold to-ssc-gold-light"
          />
          <ProductCard
            title="DISPLAYMYCARD"
            description="AI-powered photo enhancement that makes your cards look like they belong in a Beckett ad."
            iconSvg={cameraIcon}
            href="https://displaymycard.com"
            cta="Try DisplayMyCard"
            gradient="bg-gradient-to-r from-amber-500 to-amber-300"
            external
          />
          <ProductCard
            title="THE TAX PLAYBOOK"
            description="Free 62-page guide. Canadian tax rules for card sellers, GST, deductions, and record-keeping."
            iconSvg={bookIcon}
            href="/playbook"
            cta="Get It Free"
            gradient="bg-gradient-to-r from-ssc-gold-dark to-ssc-gold"
          />
        </div>
      </section>

    </div>
  </main>
  <Footer />
  <MobileStickyCTA text="Join the Waitlist" href="/waitlist" />
</BaseLayout>
