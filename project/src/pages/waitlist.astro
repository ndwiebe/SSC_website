---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import MobileStickyCTA from '../components/MobileStickyCTA.astro';
import { FullPageScrollBackground } from '../components/FullPageScrollBackground';
import { WaitlistForm } from '../components/WaitlistForm';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'SoftwareApplication',
  name: 'Slab Savvy Tracker',
  description: 'AI-powered inventory tracking for sports card dealers. Send a photo, confirm the details, and your spreadsheet updates itself with real-time comp prices.',
  url: 'https://slabsavvycpa.com/waitlist',
  applicationCategory: 'BusinessApplication',
  operatingSystem: 'Web',
  offers: {
    '@type': 'Offer',
    availability: 'https://schema.org/PreOrder',
    priceCurrency: 'CAD',
  },
};

const painPoints = [
  {
    problem: 'YOU\'RE TRACKING INVENTORY IN A NOTES APP',
    detail: 'Or a spreadsheet you started six months ago and stopped updating. Or nowhere at all. You know roughly what you have. "Roughly" doesn\'t cut it when you\'re sitting on $30,000 in cards.',
  },
  {
    problem: 'YOU DON\'T KNOW WHAT YOU PAID',
    detail: 'That Bedard rookie card you\'re about to list. Did you pay $180 or $220? Was shipping included? What about the grading fee? Without cost basis, you\'re guessing at your profit on every sale.',
  },
  {
    problem: 'COMPS TAKE FOREVER',
    detail: 'Before you price anything, you\'re on 130point searching the player, filtering by set and parallel, checking recent solds. Do that for 20 cards and your whole evening is gone.',
  },
  {
    problem: 'TAX TIME IS A SCRAMBLE',
    detail: 'Every April you\'re piecing together a year of buys, sells, and trades from PayPal receipts and DM conversations. Your accountant asks for records and you hand them a mess.',
  },
];

const steps = [
  {
    number: '01',
    title: 'SNAP A PHOTO',
    detail: 'Take a picture of the card and send it to your Slab Savvy Tracker bot on Telegram. That\'s it. No app to open, no forms to fill out.',
  },
  {
    number: '02',
    title: 'CONFIRM THE DETAILS',
    detail: 'The bot identifies the card. Player, year, set, parallel, grade. It shows you a summary. You say "bought this for $180 from Kyle at the show" and it fills in the rest.',
  },
  {
    number: '03',
    title: 'GET COMPS',
    detail: 'Recent sold prices from 130point pulled automatically. You know what the card is worth before you decide what to do with it. No separate search needed.',
  },
  {
    number: '04',
    title: 'ROW IN YOUR SHEET',
    detail: 'A row appears in your own Google Sheet. Card info, what you paid, comps, fees, profit. All the formulas are already there. Your data, your account.',
  },
];

const whoItsFor = [
  { label: 'Casual flippers', detail: 'doing 10-50 cards a month from shows and Facebook groups' },
  { label: 'Side hustle dealers', detail: 'running 50-300 cards across eBay, Whatnot, and shows' },
  { label: 'Full-time dealers', detail: 'moving 500+ cards a month who need real business records' },
  { label: 'Collectors who sell', detail: 'thinning the PC and want to know what they actually made' },
];
---

<BaseLayout
  title="Slab Savvy Tracker — Your Dealer's Assistant"
  description="Stop tracking cards in a Notes app. Send a photo, confirm the details, get a row in your spreadsheet with comps. Built for Canadian card dealers."
  jsonLd={jsonLd}
>
  <Navigation />
  <main class="flex-1">
    <div class="pb-16 md:pb-0">
      <!-- Fixed scroll animation background — Celebrini -->
      <FullPageScrollBackground client:load framePath="/hero-frames/celebrini" frameCount={73} />

      <!-- All content scrolls OVER the animation -->
      <div class="relative z-10">

        <!-- Hero -->
        <section class="min-h-screen flex items-center justify-center relative">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" style="text-shadow: 0 2px 12px rgba(0,0,0,0.7), 0 0 20px rgba(0,0,0,0.4)">
            <span class="badge-pulse inline-block bg-ssc-gold/10 border border-ssc-gold/30 text-ssc-gold font-mono text-xs tracking-widest px-4 py-1.5 mb-8">
              BETA COMING SOON
            </span>
            <h1 class="font-headline text-4xl md:text-6xl lg:text-7xl text-white tracking-wide leading-none mb-6">
              YOUR DEALER'S
              <br />
              <span class="text-shimmer" style="text-shadow: none">ASSISTANT</span>
            </h1>
            <p class="font-body text-gray-300 text-lg md:text-xl max-w-2xl mx-auto mb-4">
              Send a photo of a card. Get it logged, comped, and tracked
              in your spreadsheet. About 30 seconds.
            </p>
            <p class="font-body text-gray-400 text-sm max-w-lg mx-auto">
              Works in Telegram. No app to download. Your data stays in your Google Sheet.
            </p>
          </div>

          <!-- Scroll indicator -->
          <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
            <div class="flex flex-col items-center gap-2">
              <span class="font-body text-xs text-gray-400 tracking-wider uppercase">Scroll</span>
              <svg class="w-5 h-5 text-ssc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="square" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </section>

        <!-- Pain Points -->
        <section class="bg-ssc-black/80 backdrop-blur-md">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24">
            <div class="text-center mb-12" style="text-shadow: 0 2px 8px rgba(0,0,0,0.6)">
              <h2 class="font-headline text-3xl md:text-4xl text-ssc-gold tracking-wide mb-3">SOUND FAMILIAR?</h2>
            </div>

            <div data-animate="stagger-alternate" data-children=".pain-point" data-stagger="0.12" class="space-y-6">
              {painPoints.map((point) => (
                <div class="pain-point bg-white/5 backdrop-blur-sm border border-white/10 p-6" style="opacity: 0; text-shadow: 0 1px 4px rgba(0,0,0,0.5)">
                  <h3 class="font-headline text-lg text-ssc-gold tracking-wide mb-2">{point.problem}</h3>
                  <p class="font-body text-gray-300 text-sm leading-relaxed">{point.detail}</p>
                </div>
              ))}
            </div>

            <div class="text-center mt-10" style="text-shadow: 0 2px 8px rgba(0,0,0,0.6)">
              <p class="font-body text-gray-300 text-lg">
                Slab Savvy Tracker fixes all of this. Here's how.
              </p>
            </div>
          </div>
        </section>

        <!-- How It Works (step by step walkthrough) -->
        <section class="py-16 md:py-24">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8" style="text-shadow: 0 2px 8px rgba(0,0,0,0.6)">
            <div class="text-center mb-12 md:mb-16">
              <h2 class="font-headline text-3xl md:text-4xl text-ssc-gold tracking-wide mb-3">HOW IT ACTUALLY WORKS</h2>
              <p class="font-body text-gray-300 mt-3 max-w-2xl mx-auto">
                Text your bot like you'd text a friend. That's the whole thing.
              </p>
            </div>

            <div data-animate="stagger-scale" data-children=".step-card" data-stagger="0.15" class="space-y-6">
              {steps.map((step) => (
                <div class="step-card flex gap-5 bg-white/10 backdrop-blur-sm border border-white/10 p-6" style="opacity: 0; text-shadow: 0 1px 4px rgba(0,0,0,0.5)">
                  <div class="step-number w-12 h-12 bg-ssc-gold text-white flex items-center justify-center font-mono text-lg font-bold flex-shrink-0">
                    {step.number}
                  </div>
                  <div>
                    <h3 class="font-headline text-lg text-white tracking-wide mb-2">{step.title}</h3>
                    <p class="font-body text-gray-300 text-sm leading-relaxed">{step.detail}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- What you get (the real value) -->
        <section class="bg-ssc-black/80 backdrop-blur-md">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24" style="text-shadow: 0 2px 8px rgba(0,0,0,0.6)">
            <div class="text-center mb-12">
              <h2 class="font-headline text-3xl md:text-4xl text-ssc-gold tracking-wide mb-3">WHAT THIS MEANS FOR YOU</h2>
            </div>

            <div data-animate="stagger-scale" data-children=".value-item" data-stagger="0.08" class="grid grid-cols-1 md:grid-cols-2 gap-5">
              {[
                { title: 'KNOW YOUR PROFIT', desc: 'Every card has a cost basis. Every sale has a margin. No more guessing whether you made money this month.' },
                { title: 'COMPS IN SECONDS', desc: 'Recent sold prices pulled automatically when you log a card. You know what it\'s worth before you price it.' },
                { title: 'RECORDS THAT ARE READY', desc: 'When tax time hits, your spreadsheet is already done. Hand it to your accountant and walk away.' },
                { title: 'YOUR DATA, YOUR SHEET', desc: 'Everything lives in your own Google account. You own it completely.' },
                { title: 'LOTS AND TRADES HANDLED', desc: 'Bought a collection for $2,000? The cost gets split across every card. Traded a Crosby for a McDavid? Both sides tracked.' },
                { title: 'WORKS AT SHOWS', desc: 'Buy a card at a show, snap a photo while you\'re still at the table. It\'s logged before you get to the next booth.' },
              ].map((item) => (
                <div class="value-item bg-white/5 backdrop-blur-sm border border-white/10 p-5" style="opacity: 0; text-shadow: 0 1px 4px rgba(0,0,0,0.5)">
                  <h3 class="font-headline text-base text-ssc-gold tracking-wide mb-2">{item.title}</h3>
                  <p class="font-body text-gray-300 text-sm">{item.desc}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- Who It's For -->
        <section class="py-16 md:py-20">
          <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8" style="text-shadow: 0 2px 8px rgba(0,0,0,0.6)">
            <div class="text-center mb-10">
              <h2 class="font-headline text-3xl md:text-4xl text-ssc-gold tracking-wide mb-3">WHO IT'S FOR</h2>
            </div>

            <div data-animate="stagger-alternate" data-children=".who-item" data-stagger="0.1" class="space-y-4">
              {whoItsFor.map((item) => (
                <div class="who-item flex items-start gap-4 p-4 border border-white/10 bg-white/5 backdrop-blur-sm" style="opacity: 0; text-shadow: 0 1px 4px rgba(0,0,0,0.5)">
                  <div class="w-2 h-2 bg-ssc-gold mt-2 flex-shrink-0" />
                  <div>
                    <span class="font-mono text-ssc-gold text-sm">{item.label}</span>
                    <span class="font-body text-gray-300 text-sm"> — {item.detail}</span>
                  </div>
                </div>
              ))}
            </div>

            <div class="text-center mt-8" style="text-shadow: 0 2px 8px rgba(0,0,0,0.6)">
              <p class="font-body text-gray-400 text-sm">
                Built by a CPA who buys, sells, and trades cards every week.
              </p>
            </div>
          </div>
        </section>

        <!-- Waitlist Form -->
        <section id="waitlist-form" class="bg-ssc-black/80 backdrop-blur-md">
          <div data-animate="blur-fade" class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 text-center" style="opacity: 0; text-shadow: 0 2px 8px rgba(0,0,0,0.6)">
            <h2 class="font-headline text-3xl md:text-4xl text-ssc-gold tracking-wide mb-3">GET EARLY ACCESS</h2>
            <p class="font-body text-gray-300 mb-3 max-w-lg mx-auto">
              Beta spots are limited. First in, first tracked.
            </p>
            <p class="font-body text-gray-400 text-sm mb-8 max-w-md mx-auto">
              Free 30-day trial. No credit card. Cancel anytime.
            </p>
            <WaitlistForm client:visible />
          </div>
        </section>

      </div>

      <MobileStickyCTA text="Get Early Access" href="#waitlist-form" />
    </div>
  </main>
  <Footer />
</BaseLayout>
