---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import { SpreadsheetForm } from '../components/SpreadsheetForm';

const features = [
  'Purchase and sale tracking with cost basis',
  'Box and break cost allocation (link individual cards to a box purchase)',
  'Trade logging with FMV and comp sources',
  'Grading submission tracker with fee roll-up',
  'GST/HST rolling threshold alert (warns you before you hit $30K)',
  'Year-end summary ready to hand to your accountant',
  'Two tax-ready export views (capital gains and business income)',
];
---

<BaseLayout
  title="Card Collector's Tax Playbook Spreadsheet — Slab Savvy"
  description="Free tax tracking spreadsheet for Canadian sports card dealers. Cost basis, GST threshold monitoring, and export-ready formats."
>
  <Navigation />
  <main class="flex-1">
    <div class="min-h-screen bg-ssc-bg">
      <!-- Header -->
      <div class="bg-ssc-black text-white">
        <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
          <div class="w-16 h-16 bg-ssc-gold/10 border border-ssc-gold/30 flex items-center justify-center mx-auto mb-6 step-number">
            <svg class="w-8 h-8 text-ssc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="square" stroke-linejoin="miter" d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
          </div>
          <h1 class="font-headline text-3xl md:text-4xl text-ssc-gold tracking-wide mb-4">TAX TRACKING SPREADSHEET</h1>
          <p class="font-body text-xl text-gray-400 max-w-xl mx-auto">
            The tracking spreadsheet included with The Card Collector's Tax Playbook.
            Enter your email and access code below.
          </p>
        </div>
      </div>

      <!-- Form -->
      <div data-animate="blur-fade" style="opacity: 0">
        <SpreadsheetForm client:visible />
      </div>

      <!-- Don't have the code? -->
      <div class="max-w-lg mx-auto px-4 sm:px-6 lg:px-8 pb-12">
        <div class="bg-ssc-surface-dark border border-ssc-border-dark p-6 text-center">
          <h3 class="font-headline text-lg text-ssc-gold tracking-wide mb-3">DON'T HAVE A CODE?</h3>
          <p class="font-body text-gray-400 text-sm mb-4">
            The access code comes with The Card Collector's Tax Playbook — a free guide
            covering everything Canadian collectors need to know about taxes on card sales.
          </p>
          <span class="badge-pulse inline-flex items-center px-3 py-1 bg-ssc-gold/10 border border-ssc-gold/20 text-ssc-gold text-xs font-mono font-medium">
            FREE
          </span>
        </div>

        <!-- What you get -->
        <div data-animate="stagger-alternate" data-children=".check-item" data-stagger="0.08" class="bg-ssc-surface border border-ssc-border shadow-card p-6 mt-8">
          <h3 class="font-headline text-lg text-ssc-text tracking-wide mb-4">WHAT'S IN THE SPREADSHEET</h3>
          <div class="space-y-3">
            {features.map((item) => (
              <div class="check-item flex items-start space-x-3 p-2 border border-transparent" style="opacity: 0">
                <svg class="w-4 h-4 text-ssc-gold flex-shrink-0 mt-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square" stroke-linejoin="miter">
                  <polyline points="20 6 9 17 4 12" />
                </svg>
                <span class="font-body text-ssc-text-muted text-sm">{item}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</BaseLayout>
