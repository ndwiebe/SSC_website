---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import ProductCard from '../components/ProductCard.astro';
import MobileStickyCTA from '../components/MobileStickyCTA.astro';
import { FullPageScrollBackground } from '../components/FullPageScrollBackground';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://www.slabsavvycpa.com/#website',
  name: 'Slab Savvy',
  url: 'https://www.slabsavvycpa.com',
  publisher: { '@id': 'https://www.slabsavvycpa.com/#organization' },
};

const clipboardIcon = `<svg class="w-6 h-6 text-ssc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="square" stroke-linejoin="miter" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" /></svg>`;
const dmcLogo = `<img src="/logos/displaymycard.webp" alt="DisplayMyCard" class="w-8 h-8 object-contain" loading="lazy" />`;
const playbookCover = `<img src="/logos/tax-playbook-cover.webp" alt="The Card Collector's Tax Playbook cover" class="h-9 w-auto object-contain" loading="lazy" />`;
const scnmLogo = `<img src="/logos/scnm.svg" alt="Sports Cards Near Me" class="w-8 h-8 object-contain" loading="lazy" />`;
---

<BaseLayout
  title="Slab Savvy — Run Your Card Business"
  description="The collector's business platform. Inventory tracking, AI photo enhancement, tax guides, and consulting — built by a CPA who collects."
  jsonLd={jsonLd}
>
  <Navigation />
  <main class="flex-1">
    <div class="pb-16 md:pb-0">
      <!-- Fixed background animation -->
      <FullPageScrollBackground client:load framePath="/hero-frames/gretzky" frameCount={121} />

      <!-- All content scrolls OVER the animation -->
      <div class="relative z-10">

        <!-- 1. Hero -->
        <section class="min-h-screen flex items-center justify-center relative">
          <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center" style="text-shadow: 0 2px 8px rgba(0,0,0,0.6), 0 0px 20px rgba(0,0,0,0.3)">
            <p class="font-headline text-lg sm:text-xl tracking-[0.3em] text-ssc-gold mb-4">
              SLAB SAVVY
            </p>
            <h1 class="font-headline text-5xl sm:text-6xl md:text-7xl lg:text-8xl tracking-wide leading-none text-white mb-6">
              RUN YOUR CARD
              <br />
              <span class="text-shimmer" style="text-shadow: none">BUSINESS</span>
            </h1>
            <p class="font-body text-base sm:text-lg md:text-xl text-gray-300 max-w-2xl mx-auto mb-10">
              Inventory tracking. AI photo enhancement. Tax guides. Comps.
              One ecosystem, built by a collector who's also a CPA.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/waitlist" class="btn-shine inline-flex items-center justify-center min-h-[44px] px-8 py-3 bg-ssc-gold text-white font-body font-semibold text-lg hover:bg-ssc-gold-dark">
                Join the Waitlist
              </a>
              <a href="/playbook" class="btn-ghost-glow inline-flex items-center justify-center min-h-[44px] px-8 py-3 border-2 border-white/80 text-white font-body font-semibold text-lg transition-all duration-300">
                Get the Free Tax Guide
              </a>
            </div>
          </div>

          <!-- Scroll indicator -->
          <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
            <div class="flex flex-col items-center gap-2">
              <span class="font-body text-xs text-gray-400 tracking-wider uppercase">Scroll</span>
              <svg class="w-5 h-5 text-ssc-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="square" stroke-width="2" d="M19 9l-7 7-7-7" />
              </svg>
            </div>
          </div>
        </section>

        <!-- 2. Ecosystem -->
        <section class="py-10">
          <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="glass p-4 md:p-6 mb-4 text-center">
              <h2 class="font-headline text-2xl md:text-3xl tracking-wide text-ssc-text">THE ECOSYSTEM</h2>
            </div>
            <div data-animate="stagger-scale" data-children=".product-card" class="grid grid-cols-1 md:grid-cols-2 gap-3">
              <div class="product-card" style="opacity: 0">
                <ProductCard
                  title="SLAB SAVVY TRACKER"
                  description="Stop using a Notes app to track your $50K inventory. Send a photo. Confirm the details. Get a row in your spreadsheet with comps."
                  iconSvg={clipboardIcon}
                  href="/waitlist"
                  cta="Join the Waitlist"
                  gradient="bg-gradient-to-r from-ssc-gold to-ssc-gold-light"
                />
              </div>
              <div class="product-card" style="opacity: 0">
                <ProductCard
                  title="DISPLAYMYCARD"
                  description="AI-powered photo enhancement that makes your cards look like they belong in a Beckett ad. Team backgrounds, auto-crop, the works."
                  iconSvg={dmcLogo}
                  iconDark
                  href="https://displaymycard.com"
                  cta="Try DisplayMyCard"
                  gradient="bg-gradient-to-r from-amber-500 to-amber-300"
                  external
                />
              </div>
              <div class="product-card" style="opacity: 0">
                <ProductCard
                  title="THE TAX PLAYBOOK"
                  description="Free 62-page guide. Canadian tax rules for card sellers. GST, deductions, record-keeping, and a card tracking spreadsheet."
                  iconSvg={playbookCover}
                  href="/playbook"
                  cta="Get It Free"
                  gradient="bg-gradient-to-r from-ssc-gold-dark to-ssc-gold"
                />
              </div>
              <div class="product-card" style="opacity: 0">
                <ProductCard
                  title="SPORTS CARDS NEAR ME"
                  description="Every card shop in Canada on one premium map. Find shops and shows near you."
                  iconSvg={scnmLogo}
                  href="https://sportscardsnearme.ca"
                  cta="Browse the Map"
                  gradient="bg-gradient-to-r from-sky-400 via-purple-400 to-amber-300"
                  external
                />
              </div>
            </div>
          </div>
        </section>

        <!-- 3. Trust Section -->
        <section class="py-10">
          <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="glass p-6 md:p-8">
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 items-start">
                <!-- Left: Copy -->
                <div data-animate="slide-left" style="opacity: 0">
                  <h2 class="font-headline text-2xl md:text-3xl text-ssc-gold tracking-wide mb-4">
                    BUILT BY A COLLECTOR WHO'S ALSO A CPA
                  </h2>
                  <p class="font-body text-sm text-ssc-text-muted mb-3">
                    Most CPAs don't know what a YG is. Most card dealers don't know what an adjusted cost base is.
                    I'm both. Active in 15+ Facebook collector groups daily.
                  </p>
                  <p class="font-body text-sm text-ssc-text-muted mb-4">
                    Every tool in the ecosystem exists because I needed it myself.
                  </p>
                  <a href="/playbook" class="btn-shine inline-flex items-center min-h-[44px] px-8 py-3 bg-ssc-gold text-white font-body font-semibold hover:bg-ssc-gold-dark">
                    Get the Free Tax Guide
                    <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="square" d="M5 12h14M12 5l7 7-7 7" /></svg>
                  </a>
                </div>

                <!-- Right: Credential box -->
                <div data-animate="slide-right" class="bg-ssc-black/90 p-6" style="opacity: 0">
                  <h3 class="font-headline text-lg text-ssc-gold tracking-wide mb-4">THE CREDENTIALS</h3>
                  <ul class="space-y-3">
                    {[
                      { label: 'CPA', detail: 'Chartered Professional Accountant' },
                      { label: 'Active Collector', detail: 'hockey cards, mostly' },
                      { label: '15+ Groups', detail: 'active in Facebook collector communities' },
                      { label: 'AI-Enhanced', detail: 'every tool built to multiply output, not replace it' },
                    ].map((item) => (
                      <li class="flex items-start gap-4 group/cred">
                        <div class="w-2 h-2 bg-ssc-gold mt-2 flex-shrink-0 transition-shadow duration-300 group-hover/cred:shadow-[0_0_8px_rgba(201,162,39,0.5)]" />
                        <div>
                          <span class="font-mono text-lg text-ssc-gold">{item.label}</span>
                          <p class="font-body text-sm text-gray-400 mt-1">{item.detail}</p>
                        </div>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          </div>
        </section>

        <!-- 4. Free Guide Banner -->
        <section class="py-10">
          <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div data-animate="blur-fade" class="glass p-6 md:p-8 text-center" style="opacity: 0">
              <span class="badge-pulse inline-block bg-ssc-gold/10 border border-ssc-gold/30 text-ssc-gold font-mono text-xs tracking-widest px-3 py-1 mb-4">
                FREE — 62 PAGES
              </span>
              <h2 class="font-headline text-2xl md:text-3xl text-ssc-text tracking-wide mb-3">
                THE CARD COLLECTOR'S TAX PLAYBOOK
              </h2>
              <p class="font-body text-ssc-text-muted max-w-lg mx-auto mb-6">
                Canadian tax rules for card sellers. Includes card tracking spreadsheet.
              </p>
              <a
                class="gumroad-button btn-shine inline-flex items-center justify-center min-h-[44px] px-8 py-3 bg-ssc-gold text-ssc-black font-body font-bold hover:bg-ssc-gold-dark"
                href="https://slabsavvycpa.gumroad.com/l/tax-playbook"
              >
                Get It Free
              </a>
            </div>
          </div>
        </section>

        <!-- 5. CTA Band -->
        <section class="bg-ssc-black/80 backdrop-blur-md">
          <div data-animate="blur-fade" class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center" style="opacity: 0">
            <h2 class="font-headline text-3xl md:text-5xl text-ssc-gold tracking-wide mb-6">
              STOP WINGING IT
            </h2>
            <p class="font-body text-lg text-gray-400 max-w-2xl mx-auto mb-10">
              Your inventory deserves more than a Notes app. Your taxes deserve more than guesswork.
              Get on the list and be first in line when the full ecosystem drops.
            </p>
            <div class="flex flex-col sm:flex-row gap-4 justify-center">
              <a href="/waitlist" class="btn-shine inline-flex items-center justify-center min-h-[44px] px-10 py-4 bg-ssc-gold text-white font-body font-semibold text-lg hover:bg-ssc-gold-dark">
                Join the Waitlist
                <svg class="ml-2 w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="square" d="M5 12h14M12 5l7 7-7 7" /></svg>
              </a>
              <a href="/playbook" class="btn-ghost-glow inline-flex items-center justify-center min-h-[44px] px-10 py-4 border-2 border-white/80 text-white font-body font-semibold text-lg transition-all duration-300">
                Get the Free Tax Guide
              </a>
            </div>
          </div>
        </section>

      </div>

      <MobileStickyCTA text="Join the Waitlist" href="/waitlist" />
    </div>
  </main>
  <Footer />
</BaseLayout>
