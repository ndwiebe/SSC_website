---
import '../index.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://www.slabsavvycpa.com/og-image.png',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();

// Sitewide entity graph: the Organization and the CPA behind it (E-E-A-T anchor)
const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://www.slabsavvycpa.com/#organization',
      name: 'Slab Savvy CPA',
      alternateName: 'Slab Savvy',
      url: 'https://www.slabsavvycpa.com',
      logo: 'https://www.slabsavvycpa.com/ssc-logo.png',
      description:
        'Tools and services for sports card collectors and dealers: AI-powered inventory tracking, accountant-ready bookkeeping, Canadian tax guidance, and card photo enhancement — built by a CPA who collects.',
      email: 'slabsavvycpa@gmail.com',
      founder: { '@id': 'https://www.slabsavvycpa.com/#nathan-wiebe' },
      sameAs: ['https://facebook.com/slabsavvy'],
    },
    {
      '@type': 'Person',
      '@id': 'https://www.slabsavvycpa.com/#nathan-wiebe',
      name: 'Nathan Wiebe',
      jobTitle: 'Chartered Professional Accountant (CPA)',
      description:
        'Canadian CPA and lifelong sports card collector. Builds AI-powered tools for the hobby and writes about tax rules for card sellers in Canada.',
      worksFor: { '@id': 'https://www.slabsavvycpa.com/#organization' },
      knowsAbout: [
        'Canadian income tax for sports card sellers',
        'GST/HST for small business',
        'Sports card collecting and dealing',
        'AI automation for accounting workflows',
      ],
      sameAs: ['https://github.com/ndwiebe'],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- Enable scroll-reveal ONLY when JS is confirmed running. This inline
         script runs before first paint, so the hidden start state (gated on
         html.js-anim in index.css) applies with no flash. If JS is blocked or
         off, this never runs, nothing is hidden, and content shows normally. -->
    <script is:inline>
      document.documentElement.classList.add('js-anim');
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAFAF8" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Slab Savvy" />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="1024x1024" href="/ssc-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />

    <!-- Gumroad overlay -->
    <script src="https://gumroad.com/js/gumroad.js" defer></script>

    <!-- JSON-LD: sitewide Organization + Person (E-E-A-T), then page-specific schema -->
    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="min-h-screen bg-ssc-bg flex flex-col font-body overflow-x-hidden">
    <slot />

    <!-- PostHog -->
    <script>
      import posthog from 'posthog-js';

      const key = import.meta.env.PUBLIC_POSTHOG_KEY;
      if (key && typeof key === 'string') {
        posthog.init(key, {
          api_host: 'https://us.i.posthog.com',
          advanced_disable_feature_flags: true,
          capture_pageview: true,
          capture_pageleave: true,
          persistence: 'localStorage+cookie',
        });
      }
    </script>

    <!-- Scroll-reveal driver. Deliberately INLINE (is:inline) with no imports,
         so it can't fail to load the way a bundled module can behind a
         corporate/privacy script-blocker. It only ever ADDS visibility
         (`.anim-in`); the hidden start state lives in CSS gated on html.js-anim.
         Failure modes all degrade to "content visible": JS off -> never hides;
         reduced-motion -> CSS block inert; observer never fires -> failsafe
         sweep reveals everything. -->
    <script is:inline>
      (function () {
        var nodes = document.querySelectorAll('[data-animate]');
        if (!nodes.length) return;
        var els = [];
        for (var i = 0; i < nodes.length; i++) els.push(nodes[i]);

        // Give stagger children an index so their transition-delay cascades.
        els.forEach(function (el) {
          if ((el.getAttribute('data-animate') || '').indexOf('stagger') === 0) {
            var kids = el.children;
            for (var k = 0; k < kids.length; k++) {
              kids[k].style.setProperty('--anim-i', k);
            }
          }
        });

        // Under reduced motion the CSS never hides anything — nothing to reveal.
        if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          return;
        }

        function reveal(el) { el.classList.add('anim-in'); }
        function revealAll() { els.forEach(reveal); }

        try {
          if (!('IntersectionObserver' in window)) { revealAll(); return; }
          var io = new IntersectionObserver(function (entries) {
            entries.forEach(function (e) {
              if (e.isIntersecting) { reveal(e.target); io.unobserve(e.target); }
            });
          }, { rootMargin: '0px 0px -12% 0px' });
          els.forEach(function (el) { io.observe(el); });

          // Failsafe: never leave anything hidden, even if the observer never
          // fires (background tab, headless renderer, odd viewport math).
          var sweep = function () { setTimeout(revealAll, 2500); };
          if (document.readyState === 'complete') sweep();
          else window.addEventListener('load', sweep);
        } catch (err) {
          revealAll();
        }
      })();
    </script>
  </body>
</html>
