---
import '../index.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://www.slabsavvycpa.com/og-image.png',
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).toString();

// Sitewide entity graph: the Organization and the CPA behind it (E-E-A-T anchor)
const siteGraph = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://www.slabsavvycpa.com/#organization',
      name: 'Slab Savvy CPA',
      alternateName: 'Slab Savvy',
      url: 'https://www.slabsavvycpa.com',
      logo: 'https://www.slabsavvycpa.com/ssc-logo.png',
      description:
        'Tools and services for sports card collectors and dealers: AI-powered inventory tracking, accountant-ready bookkeeping, Canadian tax guidance, and card photo enhancement — built by a CPA who collects.',
      email: 'slabsavvycpa@gmail.com',
      founder: { '@id': 'https://www.slabsavvycpa.com/#nathan-wiebe' },
      sameAs: ['https://facebook.com/slabsavvy'],
    },
    {
      '@type': 'Person',
      '@id': 'https://www.slabsavvycpa.com/#nathan-wiebe',
      name: 'Nathan Wiebe',
      jobTitle: 'Chartered Professional Accountant (CPA)',
      description:
        'Canadian CPA and lifelong sports card collector. Builds AI-powered tools for the hobby and writes about tax rules for card sellers in Canada.',
      worksFor: { '@id': 'https://www.slabsavvycpa.com/#organization' },
      knowsAbout: [
        'Canadian income tax for sports card sellers',
        'GST/HST for small business',
        'Sports card collecting and dealing',
        'AI automation for accounting workflows',
      ],
      sameAs: ['https://github.com/ndwiebe'],
    },
  ],
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#FAFAF8" />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="Slab Savvy" />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="1024x1024" href="/ssc-logo.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@400;500;700&family=JetBrains+Mono:wght@400;700&display=swap" rel="stylesheet" />

    <!-- Gumroad overlay -->
    <script src="https://gumroad.com/js/gumroad.js" defer></script>

    <!-- JSON-LD: sitewide Organization + Person (E-E-A-T), then page-specific schema -->
    <script type="application/ld+json" set:html={JSON.stringify(siteGraph)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class="min-h-screen bg-ssc-bg flex flex-col font-body overflow-x-hidden">
    <slot />

    <!-- PostHog -->
    <script>
      import posthog from 'posthog-js';

      const key = import.meta.env.PUBLIC_POSTHOG_KEY;
      if (key && typeof key === 'string') {
        posthog.init(key, {
          api_host: 'https://us.i.posthog.com',
          advanced_disable_feature_flags: true,
          capture_pageview: true,
          capture_pageleave: true,
          persistence: 'localStorage+cookie',
        });
      }
    </script>

    <!-- GSAP animation auto-init -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      // Content is visible by default (no CSS opacity:0). GSAP only ENHANCES it
      // with scroll reveals. Two safety nets guarantee content never stays
      // blank if anything about the animation goes wrong:
      //   1. prefers-reduced-motion, or GSAP failing to load/init -> we simply
      //      never hide anything, so the page shows normally.
      //   2. a failsafe reveals any section that is on-screen but still hidden
      //      (the real-world failure: ScrollTrigger positions computed before
      //      fonts/images settle, so a trigger never fires on a slower browser).
      const REDUCE = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      // Force any on-screen [data-animate] (or its children) that is still
      // hidden to full visibility. Only touches elements in the viewport, so
      // legitimately-below-the-fold sections still animate in on scroll.
      function revealStuck() {
        document.querySelectorAll<HTMLElement>('[data-animate]').forEach((el) => {
          const r = el.getBoundingClientRect();
          const inView = r.top < window.innerHeight * 1.05 && r.bottom > 0;
          if (!inView) return;
          const type = el.dataset.animate || '';
          const targets: Element[] = type.startsWith('stagger')
            ? Array.from(el.querySelectorAll(el.dataset.children || '.animate-child'))
            : [el];
          targets.forEach((t) => {
            if (parseFloat(getComputedStyle(t).opacity) < 0.05) {
              gsap.set(t, { opacity: 1, x: 0, y: 0, scale: 1, filter: 'none', clearProps: 'transform,filter' });
            }
          });
        });
      }

      function initAnimations() {
        if (REDUCE) return; // leave everything at its natural visible state
        document.querySelectorAll<HTMLElement>('[data-animate]').forEach((el) => {
          const type = el.dataset.animate;
          const childSelector = el.dataset.children || '.animate-child';
          const stagger = parseFloat(el.dataset.stagger || '0.15');
          const delay = parseFloat(el.dataset.delay || '0');

          switch (type) {
            case 'stagger-scale': {
              gsap.fromTo(
                el.querySelectorAll(childSelector),
                { opacity: 0, y: 30, scale: 0.95, filter: 'blur(4px)' },
                {
                  opacity: 1, y: 0, scale: 1, filter: 'blur(0px)',
                  duration: 0.7, stagger, ease: 'back.out(1.2)',
                  scrollTrigger: { trigger: el, start: 'top 80%', toggleActions: 'play none none none' },
                }
              );
              break;
            }
            case 'blur-fade': {
              gsap.fromTo(
                el,
                { opacity: 0, y: 30, filter: 'blur(8px)' },
                {
                  opacity: 1, y: 0, filter: 'blur(0px)',
                  duration: 1, delay, ease: 'power3.out',
                  scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
                }
              );
              break;
            }
            case 'slide-left': {
              gsap.fromTo(
                el,
                { opacity: 0, x: -60 },
                {
                  opacity: 1, x: 0, duration: 0.8, delay, ease: 'power3.out',
                  scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
                }
              );
              break;
            }
            case 'slide-right': {
              gsap.fromTo(
                el,
                { opacity: 0, x: 60 },
                {
                  opacity: 1, x: 0, duration: 0.8, delay, ease: 'power3.out',
                  scrollTrigger: { trigger: el, start: 'top 85%', toggleActions: 'play none none none' },
                }
              );
              break;
            }
            case 'stagger-alternate': {
              const els = el.querySelectorAll(childSelector);
              els.forEach((child, i) => {
                const fromX = i % 2 === 0 ? -40 : 40;
                gsap.fromTo(
                  child,
                  { opacity: 0, x: fromX, filter: 'blur(4px)' },
                  {
                    opacity: 1, x: 0, filter: 'blur(0px)',
                    duration: 0.7, delay: i * stagger, ease: 'power2.out',
                    scrollTrigger: { trigger: el, start: 'top 80%', toggleActions: 'play none none none' },
                  }
                );
              });
              break;
            }
          }
        });
      }

      try {
        gsap.registerPlugin(ScrollTrigger);
        initAnimations();
        // Recompute trigger positions once the real layout settles (fonts +
        // images shift where 'top 85%' actually is). This is the fix for
        // triggers that never fire on slower/real browsers.
        window.addEventListener('load', () => ScrollTrigger.refresh());
        if (document.fonts && document.fonts.ready) {
          document.fonts.ready.then(() => ScrollTrigger.refresh());
        }
        // Belt-and-suspenders: after load + a beat, reveal anything on-screen
        // that never animated in. Runs again on the first scroll, cheaply.
        window.addEventListener('load', () => setTimeout(revealStuck, 1200));
        let ticking = false;
        window.addEventListener(
          'scroll',
          () => {
            if (ticking) return;
            ticking = true;
            requestAnimationFrame(() => { revealStuck(); ticking = false; });
          },
          { passive: true }
        );
      } catch (err) {
        // If GSAP failed entirely, content is already visible (never hidden);
        // nothing to do but make certain.
        document
          .querySelectorAll<HTMLElement>('[data-animate], [data-animate] .animate-child')
          .forEach((el) => { el.style.opacity = '1'; });
      }
    </script>
  </body>
</html>
