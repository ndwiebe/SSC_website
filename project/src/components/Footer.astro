    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center space-x-3">
          <img src="/ssc-logo.png" alt="Slab Savvy Logo" class="w-10 h-10 object-cover" />
          <span class="font-headline text-lg tracking-wide text-ssc-gold">SLAB SAVVY</span>
        </div>
        <p class="text-ssc-text-muted text-sm font-body">
          AI-powered tools for sports card collectors. Track inventory, stay tax-ready, and make smarter decisions.
        </p>
      </div>

      <!-- Products -->
      <div>
        <h3 class="font-headline text-sm tracking-widest text-ssc-gold mb-4">PRODUCTS</h3>
        <ul class="space-y-1 font-body text-sm">
