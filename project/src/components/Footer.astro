---
---

<footer class="bg-ssc-black text-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      <!-- Brand -->
      <div class="space-y-4">
        <div class="flex items-center space-x-3">
          <img src="/ssc-logo.png" alt="Slab Savvy Logo" class="w-10 h-10 object-cover" />
          <span class="font-headline text-lg tracking-wide text-ssc-gold">SLAB SAVVY</span>
        </div>
        <p class="text-ssc-text-muted text-sm font-body">
          AI-powered tools for sports card collectors. Track inventory, stay tax-ready, and make smarter decisions.
        </p>
      </div>

      <!-- Products -->
      <div>
        <h3 class="font-headline text-sm tracking-widest text-ssc-gold mb-4">PRODUCTS</h3>
        <ul class="space-y-1 font-body text-sm">
          <li>
            <a href="/waitlist" class="min-h-[44px] inline-flex items-center text-gray-400 hover:text-white transition-colors">
              Slab Savvy Tracker
            </a>
          </li>
          <li>
            <a href="https://displaymycard.com" target="_blank" rel="noopener noreferrer" class="min-h-[44px] inline-flex items-center text-gray-400 hover:text-white transition-colors">
              DisplayMyCard
            </a>
          </li>
          <li>
            <a href="/spreadsheet" class="min-h-[44px] inline-flex items-center text-gray-400 hover:text-white transition-colors">
              Tax Playbook
            </a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-headline text-sm tracking-widest text-ssc-gold mb-4">SERVICES</h3>
        <ul class="space-y-1 font-body text-sm">
          <li>
            <a href="/taxready" class="min-h-[44px] inline-flex items-center text-gray-400 hover:text-white transition-colors">
              Tax Ready
            </a>
          </li>
          <li>
            <a href="mailto:slabsavvycpa@gmail.com?subject=AI%20Consulting%20Inquiry" class="min-h-[44px] inline-flex items-center text-gray-400 hover:text-white transition-colors">
              AI Consulting
            </a>
          </li>
          <li>
            <a href="/blog" class="min-h-[44px] inline-flex items-center text-gray-400 hover:text-white transition-colors">
              Blog
            </a>
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div>
        <h3 class="font-headline text-sm tracking-widest text-ssc-gold mb-4">THE FLIP SHEET</h3>
        <p class="text-gray-400 text-sm font-body mb-3">Tax tips and market takes for Canadian card dealers.</p>
        <form id="footer-newsletter-form" class="space-y-2">
          <input
            type="email"
            id="footer-newsletter-email"
            placeholder="your@email.com"
            required
            class="w-full px-3 py-2 min-h-[44px] bg-ssc-surface-dark border border-ssc-border-dark text-white font-body text-sm placeholder:text-gray-500 focus:outline-none focus:border-ssc-gold"
          />
          <button
            type="submit"
            class="w-full btn-shine bg-ssc-gold hover:bg-ssc-gold-dark text-white px-3 py-2 min-h-[44px] font-body font-semibold text-sm"
          >
            Subscribe
          </button>
        </form>
        <p id="footer-newsletter-success" class="hidden text-ssc-gold text-sm font-body mt-2">You're in.</p>
        <p id="footer-newsletter-error" class="hidden text-red-400 text-sm font-body mt-2"></p>
        <div class="mt-4 flex gap-4">
          <a href="mailto:slabsavvycpa@gmail.com" class="text-gray-500 hover:text-white transition-colors text-sm font-body">Email</a>
          <a href="https://facebook.com/slabsavvy" target="_blank" rel="noopener noreferrer" class="text-gray-500 hover:text-white transition-colors text-sm font-body">Facebook</a>
        </div>
      </div>
    </div>

    <div class="border-t border-ssc-border-dark mt-8 pt-8 text-center text-ssc-text-muted text-sm font-body">
      <p>&copy; {new Date().getFullYear()} Slab Savvy. All rights reserved.</p>
    </div>
  </div>
</footer>

<script>
  import posthog from 'posthog-js';

  const form = document.getElementById('footer-newsletter-form') as HTMLFormElement;
  const emailInput = document.getElementById('footer-newsletter-email') as HTMLInputElement;
  const successMsg = document.getElementById('footer-newsletter-success');
  const errorMsg = document.getElementById('footer-newsletter-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = emailInput.value.trim();
    if (!email) return;

    errorMsg?.classList.add('hidden');

    try {
      const supabaseUrl = import.meta.env.PUBLIC_SUPABASE_URL;
      const res = await fetch(`${supabaseUrl}/functions/v1/submit-waitlist`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, monthly_volume: 'newsletter-footer' }),
      });
      const data = await res.json();

      if (!res.ok || !data.success) {
        if (errorMsg) { errorMsg.textContent = data.error || 'Something went wrong.'; errorMsg.classList.remove('hidden'); }
        return;
      }

      posthog.capture('newsletter_signup', { source: 'footer' });
      form.classList.add('hidden');
      successMsg?.classList.remove('hidden');
    } catch {
      if (errorMsg) { errorMsg.textContent = 'Network error. Try again.'; errorMsg.classList.remove('hidden'); }
    }
  });
</script>
