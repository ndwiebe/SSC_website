---
interface Props {
  title: string;
  description: string;
  iconSvg: string;
  href: string;
  cta: string;
  gradient: string;
  external?: boolean;
}

const { title, description, iconSvg, href, cta, gradient, external = false } = Astro.props;

const linkProps = external
  ? { href, target: '_blank', rel: 'noopener noreferrer' }
  : { href };
---

<a
  {...linkProps}
  class={`group relative border border-ssc-border/80 bg-white/90 backdrop-blur-sm p-5 card-hover flex flex-col`}
>
  <!-- Gradient accent bar -->
  <div class={`absolute top-0 left-0 right-0 h-1 ${gradient} accent-bar-animated`} />

  <!-- Icon + Title -->
  <div class="flex items-center gap-3 mb-3">
    <div class="w-10 h-10 bg-ssc-gold/10 border border-ssc-gold/20 flex items-center justify-center flex-shrink-0 transition-all duration-300 group-hover:bg-ssc-gold/20 group-hover:border-ssc-gold/40 group-hover:shadow-[0_0_12px_rgba(201,162,39,0.2)]">
      <Fragment set:html={iconSvg} />
    </div>
    <h3 class="font-headline text-lg tracking-wide text-ssc-text">{title}</h3>
  </div>

  <!-- Description -->
  <p class="font-body text-sm text-ssc-text-muted mb-4 flex-1">{description}</p>

  <!-- CTA -->
  <span class="inline-flex items-center min-h-[44px] text-ssc-gold font-body font-semibold transition-all duration-300 group-hover:text-ssc-gold-dark">
    {cta}
    <svg class="ml-2 w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="square" d="M5 12h14M12 5l7 7-7 7" />
    </svg>
  </span>
</a>
